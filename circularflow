<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Circular Flow Model Simulation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @keyframes dashForward {
            from {
                stroke-dashoffset: 20;
            }
            to {
                stroke-dashoffset: 0;
            }
        }
        
        @keyframes dashBackward {
            from {
                stroke-dashoffset: 0;
            }
            to {
                stroke-dashoffset: 20;
            }
        }

        .path-monetary {
            stroke-dasharray: 10 10;
            animation: dashForward 1s linear infinite;
            transition: stroke-width 0.3s ease;
        }

        .path-real {
            stroke-dasharray: 10 10;
            animation: dashForward 1s linear infinite;
            transition: stroke-width 0.3s ease;
        }

        .node-shadow {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
        
        input[type=range] {
            accent-color: #3b82f6;
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 font-sans p-4 md:p-8 min-h-screen flex flex-col items-center">

    <div class="max-w-6xl w-full flex flex-col gap-8">
        
        <!-- Header -->
        <div class="text-center">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Circular Flow Model</h1>
            <p class="text-gray-600 max-w-3xl mx-auto">
                This interactive simulation demonstrates the flow of money, resources, and goods in an economy. 
                Adjust the spending variables to observe the dynamic impact on the total Gross Domestic Product.
            </p>
        </div>

        <!-- Main Content Area -->
        <div class="flex flex-col lg:flex-row gap-6">
            
            <!-- Visualization Container -->
            <div class="flex-grow bg-white rounded-2xl p-4 shadow-lg border border-gray-200 relative aspect-[4/3] w-full max-w-4xl mx-auto overflow-hidden">
                
                <!-- SVG Paths -->
                <svg viewBox="0 0 800 600" class="absolute inset-0 w-full h-full pointer-events-none">
                    <defs>
                        <marker id="arrow-monetary" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto" markerUnits="strokeWidth">
                            <path d="M0,0 L0,6 L9,3 z" fill="#22c55e" />
                        </marker>
                        <marker id="arrow-real" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto" markerUnits="strokeWidth">
                            <path d="M0,0 L0,6 L9,3 z" fill="#3b82f6" />
                        </marker>
                    </defs>

                    <!-- Outer Loop: Monetary Flow (Green, Clockwise) -->
                    <!-- Households to Product Market -->
                    <path d="M 460,100 Q 700,100 700,250" fill="none" stroke="#22c55e" class="path-monetary" marker-end="url(#arrow-monetary)"/>
                    <!-- Product Market to Firms -->
                    <path d="M 700,350 Q 700,500 480,500" fill="none" stroke="#22c55e" class="path-monetary" marker-end="url(#arrow-monetary)"/>
                    <!-- Firms to Factor Market -->
                    <path d="M 340,500 Q 100,500 100,350" fill="none" stroke="#22c55e" class="path-monetary" marker-end="url(#arrow-monetary)"/>
                    <!-- Factor Market to Households -->
                    <path d="M 100,250 Q 100,100 320,100" fill="none" stroke="#22c55e" class="path-monetary" marker-end="url(#arrow-monetary)"/>

                    <!-- Inner Loop: Real Flow (Blue, Counter-Clockwise) -->
                    <!-- Households to Factor Market -->
                    <path d="M 380,100 Q 160,130 160,250" fill="none" stroke="#3b82f6" class="path-real" marker-end="url(#arrow-real)"/>
                    <!-- Factor Market to Firms -->
                    <path d="M 160,350 Q 160,470 320,500" fill="none" stroke="#3b82f6" class="path-real" marker-end="url(#arrow-real)"/>
                    <!-- Firms to Product Market -->
                    <path d="M 420,500 Q 640,470 640,350" fill="none" stroke="#3b82f6" class="path-real" marker-end="url(#arrow-real)"/>
                    <!-- Product Market to Households -->
                    <path d="M 640,250 Q 640,130 480,100" fill="none" stroke="#3b82f6" class="path-real" marker-end="url(#arrow-real)"/>
                </svg>

                <!-- HTML Overlays for Nodes (Using Percentages for accurate viewBox scaling) -->
                <div class="absolute top-[6.67%] left-[40%] w-[20%] h-[10%] bg-gray-800 text-white rounded-xl flex items-center justify-center font-bold text-sm md:text-lg node-shadow border-2 border-gray-900 z-10">
                    Households
                </div>
                <div class="absolute top-[83.33%] left-[40%] w-[20%] h-[10%] bg-gray-800 text-white rounded-xl flex items-center justify-center font-bold text-sm md:text-lg node-shadow border-2 border-gray-900 z-10">
                    Firms
                </div>
                <div class="absolute top-[45%] left-[5%] w-[20%] h-[10%] bg-slate-600 text-white rounded-xl flex items-center justify-center font-bold text-xs md:text-base node-shadow border-2 border-slate-700 text-center px-2 z-10">
                    Factor Market
                </div>
                <div class="absolute top-[45%] left-[75%] w-[20%] h-[10%] bg-slate-600 text-white rounded-xl flex items-center justify-center font-bold text-xs md:text-base node-shadow border-2 border-slate-700 text-center px-2 z-10">
                    Product Market
                </div>

                <!-- HTML Overlays for Labels -->
                <!-- Monetary Labels (Outer) -->
                <div class="absolute top-[8%] left-[65%] w-[20%] text-green-700 font-bold text-[0.6rem] md:text-sm text-center">
                    Consumption Spending
                </div>
                <div class="absolute top-[80%] left-[67%] w-[20%] text-green-700 font-bold text-[0.6rem] md:text-sm text-center">
                    Firm Revenue
                </div>
                <div class="absolute top-[80%] left-[13%] w-[20%] text-green-700 font-bold text-[0.6rem] md:text-sm text-center">
                    Factor Payments
                </div>
                <div class="absolute top-[8%] left-[15%] w-[20%] text-green-700 font-bold text-[0.6rem] md:text-sm text-center">
                    Household Income
                </div>

                <!-- Real Labels (Inner) -->
                <div class="absolute top-[28%] left-[23%] w-[15%] text-blue-700 font-semibold text-[0.55rem] md:text-xs text-center">
                    Factors of Production
                </div>
                <div class="absolute top-[63%] left-[23%] w-[15%] text-blue-700 font-semibold text-[0.55rem] md:text-xs text-center">
                    Resources
                </div>
                <div class="absolute top-[63%] left-[62%] w-[15%] text-blue-700 font-semibold text-[0.55rem] md:text-xs text-center">
                    Goods & Services
                </div>
                <div class="absolute top-[28%] left-[62%] w-[15%] text-blue-700 font-semibold text-[0.55rem] md:text-xs text-center">
                    Goods & Services
                </div>
            </div>

            <!-- Controls and Summary Panel -->
            <div class="w-full lg:w-96 flex flex-col gap-4">
                
                <!-- Sliders Panel -->
                <div class="bg-white p-5 rounded-2xl shadow-lg border border-gray-200">
                    <h2 class="text-xl font-bold text-gray-800 mb-4 border-b pb-2">Economic Variables</h2>
                    
                    <div class="flex flex-col gap-5">
                        <div>
                            <div class="flex justify-between mb-1">
                                <label for="consumption" class="font-medium text-gray-700 text-sm">Consumption Spending</label>
                                <span id="val-c" class="font-bold text-blue-600">$1000</span>
                            </div>
                            <input type="range" id="consumption" min="500" max="1500" step="10" value="1000" class="w-full">
                        </div>

                        <div>
                            <div class="flex justify-between mb-1">
                                <label for="investment" class="font-medium text-gray-700 text-sm">Investment Spending</label>
                                <span id="val-i" class="font-bold text-blue-600">$100</span>
                            </div>
                            <input type="range" id="investment" min="0" max="500" step="10" value="100" class="w-full">
                        </div>

                        <div>
                            <div class="flex justify-between mb-1">
                                <label for="government" class="font-medium text-gray-700 text-sm">Government Spending</label>
                                <span id="val-g" class="font-bold text-blue-600">$150</span>
                            </div>
                            <input type="range" id="government" min="0" max="500" step="10" value="150" class="w-full">
                        </div>
                    </div>
                </div>

                <!-- Summary Panel -->
                <div class="bg-slate-800 text-white p-5 rounded-2xl shadow-lg border border-slate-700 flex-grow">
                    <h2 class="text-xl font-bold mb-4 border-b border-slate-600 pb-2">Economic Summary</h2>
                    
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between items-center bg-slate-700 p-3 rounded-lg">
                            <span class="font-semibold text-slate-200">Total Gross Domestic Product</span>
                            <span id="val-total" class="text-2xl font-bold text-green-400">$1250</span>
                        </div>
                        
                        <p class="text-slate-300 leading-relaxed mt-4">
                            The calculation above uses the Expenditure Approach. The national income identity dictates that total income must equal total expenditure in the economy.
                        </p>
                        
                        <div class="bg-slate-700 p-3 rounded-lg mt-2 font-mono text-xs text-center text-slate-300">
                            Gross Domestic Product = Consumption + Investment + Government Spending
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const consumptionInput = document.getElementById("consumption");
            const investmentInput = document.getElementById("investment");
            const governmentInput = document.getElementById("government");

            const valC = document.getElementById("val-c");
            const valI = document.getElementById("val-i");
            const valG = document.getElementById("val-g");
            const valTotal = document.getElementById("val-total");

            const monetaryPaths = document.querySelectorAll(".path-monetary");
            const realPaths = document.querySelectorAll(".path-real");

            function updateSimulation() {
                const consumption = parseInt(consumptionInput.value, 10);
                const investment = parseInt(investmentInput.value, 10);
                const government = parseInt(governmentInput.value, 10);

                // Calculate Total Gross Domestic Product
                const totalGrossDomesticProduct = consumption + investment + government;

                // Update text displays
                valC.textContent = "$" + consumption;
                valI.textContent = "$" + investment;
                valG.textContent = "$" + government;
                valTotal.textContent = "$" + totalGrossDomesticProduct;

                // Visual Feedback: Scale path thickness based on the total economy size
                // A base thickness of 2, scaling upwards as the total increases
                const thicknessScale = Math.max(2, (totalGrossDomesticProduct / 1000) * 3);
                
                monetaryPaths.forEach(path => {
                    path.style.strokeWidth = thicknessScale + "px";
                });
                
                realPaths.forEach(path => {
                    path.style.strokeWidth = thicknessScale + "px";
                });
            }

            // Attach event listeners to all sliders
            consumptionInput.addEventListener("input", updateSimulation);
            investmentInput.addEventListener("input", updateSimulation);
            governmentInput.addEventListener("input", updateSimulation);

            // Run initial calculation on page load
            updateSimulation();
        });
    </script>
</body>
</html>
